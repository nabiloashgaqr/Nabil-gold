+        return str(trade.get("status", "")).upper() not in {"OPEN", "PARTIAL", "TP1_HIT", "PENDING"}
+
+    def _snapshot(self, trade: Dict[str, Any]) -> Dict[str, Any]:
+        snap = trade.get("signal_snapshot", {}) or {}
