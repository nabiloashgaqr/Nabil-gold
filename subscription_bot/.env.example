# Nabil Gold – Subscription Bot
# Integrated with Nabil-gold repo – shares Supabase + Telegram channel

# --- Bot Token ---
# Prefer dedicated subscription bot token:
SUBSCRIPTION_BOT_TOKEN=8061234567:AAH...
# Fallbacks supported in code:
# BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=...

# --- Supabase – SAME as Nabil Gold ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# or SUPABASE_SERVICE_KEY=...

# --- Admin ---
# Get your Telegram ID from @userinfobot
ADMIN_IDS=123456789,987654321
ADMIN_CONTACT=@Smart_Pro2026

# --- Target channel ---
# Leave empty to auto-use TELEGRAM_CHAT_ID from Nabil Gold
TARGET_CHAT_ID=-1001234567890
# or use: TELEGRAM_CHAT_ID=-100...
ADMIN_GROUP_ID=

# --- General ---
TIMEZONE=Asia/Hebron

# --- Nabil Gold shared (optional if running integrated) ---
# TELEGRAM_BOT_TOKEN=...      # signals bot – different from subscription bot
# TELEGRAM_CHAT_ID=-100...    # same private channel
# TWELVEDATA_API_KEY=...
# GEMINI_API_KEY=...
